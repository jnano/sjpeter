# Docker build context 제외 목록 (v1.5.459)
# 이 파일이 없으면 venv·__pycache__·uploads 등 전부가 build context 로 들어가
# 빌드 시간 + 이미지 크기 + 빌드 보안(시크릿 누출) 위험.

# Python
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# 런타임 데이터 — Volume 으로 마운트되니 이미지에 포함 금지
uploads/
private-uploads/
backups/

# 환경/시크릿
.env
.env.local
.env.*.local

# 개발 도구
.git/
.gitignore
.vscode/
.idea/
.DS_Store

# 임시 파일
*.log
*.swp
*.bak
*~

# 문서·README — 이미지에 포함할 필요 없음
docs/
*.md
!alembic/README.md

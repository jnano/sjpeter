# docker-compose 환경 변수 템플릿 (v1.5.456)
# 사용: cp .env.docker.example .env.docker && 값 채우고 git ignore

# ── PostgreSQL ──
POSTGRES_USER=cathedral
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=cathedral

# ── Backend ──
# 32자 이상 랜덤 문자열 (python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=CHANGE_ME_32_or_more_random_chars
INTERNAL_API_SECRET=CHANGE_ME_32_or_more_random_chars

# 콤마 구분. 운영 도메인 정해지면 추가
CORS_ORIGINS=http://localhost:3000

ENV=production
RATE_LIMIT_PER_MINUTE=200
SITE_URL=http://localhost:3000
BACKEND_PORT=8000

# ── Frontend ──
# 외부에서 접근할 백엔드 URL (운영 시 https://api.example.com 등)
NEXT_PUBLIC_API_URL=http://localhost:8000
# NextAuth 시크릿 — 32자 이상 (별도 발급)
AUTH_SECRET=CHANGE_ME_32_or_more_random_chars
FRONTEND_PORT=3000
